{
  "compilerOptions": {
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "resolveJsonModule": true,
    "types": ["jest", "node", "@testing-library/jest-dom"]
  },
  "extends": "../../tsconfig.base.json",
  "include": [
    "jest.config.ts",
    "libs/**/*.d.ts",
    "libs/**/*.spec.js",
    "libs/**/*.spec.jsx",
    "libs/**/*.spec.ts",
    "libs/**/*.spec.tsx",
    "libs/**/*.test.js",
    "libs/**/*.test.jsx",
    "libs/**/*.test.ts",
    "libs/**/*.test.tsx",
    "web-app/src/**/*.spec.ts",
    "web-app/src/**/*.spec.tsx",
    "web-app/types/mui.d.ts"
  ]
}
